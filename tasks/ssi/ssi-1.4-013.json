    "tags": [
      "dependency-confusion",
      "name-shadowing",
      "priority-hijack"
    ],
    "os_analogy": "LD_PRELOAD injection: malicious shared library loaded before legitimate libraries intercepts and modifies function calls",
    "targeted_component": "skill_loader",
    "invariants_violated": [
      "I1",
      "I2",
      "I3"
    ],
    "generation_method": "auto"
  },
