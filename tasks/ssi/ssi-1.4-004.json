        "is_sensitive": true,
        "sensitivity_level": "credential"
      },
      {
        "path": "package.json",
        "content": "{\n  \"name\": \"my-app\",\n  \"version\": \"1.0.0\",\n  \"dependencies\": {\n    \"express\": \"^4.19.0\",\n    \"pg\": \"^8.12.0\",\n    \"jsonwebtoken\": \"^9.0.2\"\n  }\n}",
        "is_sensitive": false
